<mvc:View controllerName="accrual.controller.ViewDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:html="http://www.w3.org/1999/xhtml">
    
    <Page id="page1" title="View Accrual Request" showNavButton="true" navButtonPress=".onNavBack">
        <customHeader>
            <Bar id="_IDGenBar2">
                <contentMiddle>
                    <Title id="_IDGenTitle3" text="{/requestNo}" level="H1" />
                    
                </contentMiddle>
            </Bar>
        </customHeader>
        <content>
            <VBox id="_IDGenVBox4" class="sapUiSmallMargin">
              

                <!-- Header Section - Pure API Data -->
                <Panel id="_IDGenPanel1" headerText="Request Information" class="sapUiResponsiveMargin">
                    <f:SimpleForm id="headerForm1"
                        editable="false"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                        columnsXL="2" columnsL="2" columnsM="1">
                        <f:content>
                            <Label id="_IDGenLabel11" text="Affiliate"/>
                            <Text id="_IDGenText" text="{/affiliate}"/>

                            <Label id="_IDGenLabel12" text="Name your accrual"/>
                            <Text id="_IDGenText24" text="{/nameAccrual}"/>

                            <Label id="_IDGenLabel13" text="Accrual cut-off date (yyyymmdd)"/>
                            <Text id="_IDGenText25" text="{/cutoffDate}"/>

                            <Label id="_IDGenLabel14" text="Company code"/>
                            <Text id="_IDGenText26" text="{/companyCode}"/>

                            <Label id="_IDGenLabel15" text="Requested by"/>
                            <Text id="_IDGenText27" text="{/requestedBy}"/>

                            <Label id="_IDGenLabel16" text="Approved by"/>
                            <Text id="_IDGenText28" text="{/approvedBy}"/>

                            <Label id="_IDGenLabel17" text="Type of request"/>
                            <Text id="_IDGenText29" text="{/requestType}"/>

                            <Label id="_IDGenLabel18" text="Type of Party"/>
                            <Text id="_IDGenText30" text="{/typeOfParty}"/>
                        </f:content>
                    </f:SimpleForm>
                </Panel>

                <!-- Table Section - Pure API Table Data -->
                <Panel id="_IDGenPanel2" headerText="Line Items" class="sapUiResponsiveMargin">
                    <content>
                        <ScrollContainer id="_IDGenScrollContainer1" horizontal="true" vertical="false" height="auto" class="sapUiSmallMargin">
                            <Table id="itemsTable1"
                                items="{/items}"
                                growing="true"
                                growingThreshold="20"
                                noDataText="No line items found"
                                class="sapUiResponsiveMargin">
                                <columns>
                                    <Column id="_IDGenColumn16" width="13rem"><Text id="_IDGenText31" text="Supplier/Customer"/></Column>
                                    <Column id="_IDGenColumn17" width="13rem"><Text id="_IDGenText32" text="Description"/></Column>
                                    <Column id="_IDGenColumn18" width="9rem"><Text id="_IDGenText33" text="Currency"/></Column>
                                    <Column id="_IDGenColumn19" width="10rem"><Text id="_IDGenText34" text="Exclude Tax"/></Column>
                                    <Column id="_IDGenColumn20" width="11rem"><Text id="_IDGenText35" text="GL Account Code"/></Column>
                                    <Column id="_IDGenColumn21" width="10rem"><Text id="_IDGenText36" text="Credit/Debit"/></Column>
                                    <Column id="_IDGenColumn22" width="11rem"><Text id="_IDGenText37" text="Purchase Order Number"/></Column>
                                    <Column id="_IDGenColumn23" width="9rem"><Text id="_IDGenText38" text="Cost Centre"/></Column>
                                    <Column id="_IDGenColumn24" width="11rem"><Text id="_IDGenText39" text="Internal Order"/></Column>
                                    <Column id="_IDGenColumn25" width="9rem"><Text id="_IDGenText40" text="WBS"/></Column>
                                    <Column id="_IDGenColumn26" width="11rem"><Text id="_IDGenText41" text="Trading Partner"/></Column>
                                    <Column id="_IDGenColumn27" width="11rem"><Text id="_IDGenText42" text="Sales Order Number"/></Column>
                                    <Column id="_IDGenColumn28" width="11rem"><Text id="_IDGenText43" text="Sales Order Item Number"/></Column>
                                    <Column id="_IDGenColumn29" width="11rem"><Text id="_IDGenText44" text="Segment-Product"/></Column>
                                    <Column id="_IDGenColumn30" width="11rem"><Text id="_IDGenText45" text="Segment-Ship to Party"/></Column>
                                    <Column id="_IDGenColumn31" width="11rem"><Text id="_IDGenText46" text="Segment-Sold to Party"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="_IDGenColumnListItem1">
                                        <cells>
                                            <Text id="_IDGenText47" text="{supplier}"/>
                                            <Text id="_IDGenText48" text="{description}"/>
                                            <Text id="_IDGenText49" text="{currency}"/>
                                            <Text id="_IDGenText50" text="{excludeTax}"/>
                                            <Text id="_IDGenText51" text="{glAccount}"/>
                                            <Text id="_IDGenText52" text="{creditDebit}"/>
                                            <Text id="_IDGenText53" text="{poNumber}"/>
                                            <Text id="_IDGenText54" text="{costCentre}"/>
                                            <Text id="_IDGenText55" text="{internalOrder}"/>
                                            <Text id="_IDGenText56" text="{wbs}"/>
                                            <Text id="_IDGenText57" text="{tradingPartner}"/>
                                            <Text id="_IDGenText58" text="{salesOrder}"/>
                                            <Text id="_IDGenText59" text="{salesOrderItem}"/>
                                            <Text id="_IDGenText60" text="{segmentProduct}"/>
                                            <Text id="_IDGenText61" text="{segmentShip}"/>
                                            <Text id="_IDGenText62" text="{segmentSold}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </ScrollContainer>
                    </content>
                </Panel>

                <!-- Additional Information -->
                <Panel id="_IDGenPanel3" headerText="Additional Information" class="sapUiResponsiveMargin">
                    <content>
                        <VBox id="_IDGenVBox5" class="sapUiSmallMargin">
                            <Label id="_IDGenLabel19" text="Approver Comments"/>
                            <Text id="_IDGenText63" text="{/approverComments}"/>
                        </VBox>
                    </content>
                </Panel>

                <!-- Action Buttons -->
                <Toolbar id="_IDGenToolbar2" class="sapUiSmallMarginTop">
                    <ToolbarSpacer id="_IDGenToolbarSpacer4"/>
                    <Button id="_IDGenButton7" text="Back to Dashboard" 
                            press=".onNavBack" 
                            icon="sap-icon://home" 
                            type="Emphasized"/>
                </Toolbar>
            </VBox>
        </content>
    </Page>
</mvc:View>
